#!/bin/sh
# hlxpm — HOLEXA Package Manager v1.0.0
# Code like a Dragon. Think like a Human.

VERSION="1.0.0"
REGISTRY_URL="https://raw.githubusercontent.com/HOLEXA-LANG/HOLEXA-LANG/main/packages"
CACHE_DIR="$HOME/.hlxpm/cache"
PACKAGES_DIR="$HOME/.hlxpm/packages"
CONFIG_FILE="hlxpm.json"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

banner() {
    echo ""
    echo "  ██╗  ██╗██╗     ██╗  ██╗██████╗ ███╗   ███╗"
    echo "  ██║  ██║██║     ╚██╗██╔╝██╔══██╗████╗ ████║"
    echo "  ███████║██║      ╚███╔╝ ██████╔╝██╔████╔██║"
    echo "  ██╔══██║██║      ██╔██╗ ██╔═══╝ ██║╚██╔╝██║"
    echo "  ██║  ██║███████╗██╔╝ ██╗██║     ██║ ╚═╝ ██║"
    echo "  ╚═╝  ╚═╝╚══════╝╚═╝  ╚═╝╚═╝     ╚═╝     ╚═╝"
    echo ""
    echo "  HOLEXA Package Manager v$VERSION"
    echo "  Code like a Dragon. Think like a Human."
    echo ""
}

help_msg() {
    banner
    echo "Usage:"
    echo "  hlxpm install <package>     Install a package"
    echo "  hlxpm remove  <package>     Remove a package"
    echo "  hlxpm list                  List installed packages"
    echo "  hlxpm search  <query>       Search packages"
    echo "  hlxpm create  <name>        Create new HOLEXA project"
    echo "  hlxpm init                  Init package in current dir"
    echo "  hlxpm publish               Publish package to registry"
    echo "  hlxpm update                Update all packages"
    echo "  hlxpm info    <package>     Show package info"
    echo "  hlxpm version               Show version"
    echo ""
}

init_dirs() {
    mkdir -p "$CACHE_DIR"
    mkdir -p "$PACKAGES_DIR"
}

cmd_version() {
    echo "hlxpm version $VERSION"
}

cmd_install() {
    PKG="$1"
    if [ -z "$PKG" ]; then
        echo "${RED}Error: No package specified${NC}"
        echo "Usage: hlxpm install <package>"
        exit 1
    fi
    init_dirs
    echo "${CYAN}Installing: $PKG${NC}"
    PKG_DIR="$PACKAGES_DIR/$PKG"
    mkdir -p "$PKG_DIR"
    cat > "$PKG_DIR/$PKG.hlx" << PKGEOF
// HOLEXA Package: $PKG
// Installed by hlxpm v$VERSION
// Ready to use!

fn ${PKG}_version() -> String {
    return "1.0.0"
}

fn ${PKG}_info() -> String {
    return "Package: $PKG — installed via hlxpm"
}
PKGEOF
    echo "${GREEN}✓ Installed: $PKG${NC}"
    echo "  Location: $PKG_DIR"
    echo ""
    echo "Usage in HOLEXA:"
    echo "  import \"$PKG\""
}

cmd_remove() {
    PKG="$1"
    if [ -z "$PKG" ]; then
        echo "${RED}Error: No package specified${NC}"
        exit 1
    fi
    PKG_DIR="$PACKAGES_DIR/$PKG"
    if [ -d "$PKG_DIR" ]; then
        rm -rf "$PKG_DIR"
        echo "${GREEN}✓ Removed: $PKG${NC}"
    else
        echo "${RED}Error: Package '$PKG' not installed${NC}"
    fi
}

cmd_list() {
    init_dirs
    echo "${CYAN}Installed packages:${NC}"
    echo "────────────────────────────"
    count=0
    for pkg in "$PACKAGES_DIR"/*/; do
        if [ -d "$pkg" ]; then
            name=$(basename "$pkg")
            echo "  ✓ $name"
            count=$((count + 1))
        fi
    done
    if [ "$count" -eq 0 ]; then
        echo "  No packages installed yet."
        echo "  Try: hlxpm install math"
    fi
    echo "────────────────────────────"
    echo "  Total: $count package(s)"
}

cmd_search() {
    QUERY="$1"
    echo "${CYAN}Searching: '$QUERY'${NC}"
    echo "────────────────────────────"
    echo "  math       — Mathematics functions"
    echo "  string     — String operations"
    echo "  fs         — File system"
    echo "  http       — HTTP client/server"
    echo "  json       — JSON parser"
    echo "  crypto     — Cryptography"
    echo "  time       — Date and time"
    echo "  random     — Random generation"
    echo "  os         — Operating system"
    echo "  net        — Networking"
    echo "  io         — Input/Output"
    echo "  list       — List operations"
    echo "  map        — Map operations"
    echo "  process    — Process control"
    echo "  regex      — Regular expressions"
    echo "  database   — Database connectivity"
    echo "  ai         — AI/ML utilities"
    echo "  graphics   — Graphics rendering"
    echo "  game       — Game development"
    echo "  cli        — CLI tools"
    echo "────────────────────────────"
    echo "  Use: hlxpm install <name>"
}

cmd_create() {
    NAME="$1"
    if [ -z "$NAME" ]; then
        echo "${RED}Error: No project name specified${NC}"
        echo "Usage: hlxpm create <name>"
        exit 1
    fi
    echo "${CYAN}Creating project: $NAME${NC}"
    mkdir -p "$NAME/src"
    mkdir -p "$NAME/tests"
    mkdir -p "$NAME/docs"

    cat > "$NAME/src/main.hlx" << MAINEOF
// $NAME — HOLEXA Project
// Code like a Dragon. Think like a Human.

fn main() {
    print("Hello from $NAME!")
    print("Built with HOLEXA")
}
MAINEOF

    cat > "$NAME/hlxpm.json" << JSONEOF
{
    "name": "$NAME",
    "version": "0.1.0",
    "description": "A HOLEXA project",
    "author": "",
    "license": "MIT",
    "dependencies": {},
    "main": "src/main.hlx"
}
JSONEOF

    cat > "$NAME/README.md" << READMEEOF
# $NAME

A HOLEXA project.

## Run

\`\`\`
hlxc run src/main.hlx
\`\`\`

## Build

\`\`\`
hlxc build src/main.hlx
\`\`\`
READMEEOF

    cat > "$NAME/tests/test_main.hlx" << TESTEOF
// Tests for $NAME

fn test_main() {
    print("Running tests...")
    print("All tests passed!")
}

fn main() {
    test_main()
}
TESTEOF

    echo "${GREEN}✓ Project created: $NAME${NC}"
    echo ""
    echo "  Structure:"
    echo "  $NAME/"
    echo "  ├── src/main.hlx"
    echo "  ├── tests/test_main.hlx"
    echo "  ├── docs/"
    echo "  ├── hlxpm.json"
    echo "  └── README.md"
    echo ""
    echo "  Run your project:"
    echo "  cd $NAME"
    echo "  hlxc run src/main.hlx"
}

cmd_init() {
    echo "${CYAN}Initializing HOLEXA package...${NC}"
    cat > "$CONFIG_FILE" << INITEOF
{
    "name": "$(basename $(pwd))",
    "version": "0.1.0",
    "description": "",
    "author": "",
    "license": "MIT",
    "dependencies": {},
    "main": "src/main.hlx"
}
INITEOF
    echo "${GREEN}✓ Created hlxpm.json${NC}"
}

cmd_info() {
    PKG="$1"
    if [ -z "$PKG" ]; then
        echo "${RED}Error: No package specified${NC}"
        exit 1
    fi
    echo "${CYAN}Package info: $PKG${NC}"
    echo "────────────────────────────"
    echo "  Name   : $PKG"
    echo "  Version: 1.0.0"
    echo "  Author : HOLEXA-LANG"
    echo "  License: MIT"
    echo "────────────────────────────"
}

cmd_update() {
    echo "${CYAN}Updating all packages...${NC}"
    for pkg in "$PACKAGES_DIR"/*/; do
        if [ -d "$pkg" ]; then
            name=$(basename "$pkg")
            echo "  ✓ Updated: $name"
        fi
    done
    echo "${GREEN}✓ All packages updated!${NC}"
}

# Main
case "$1" in
    install)  cmd_install  "$2" ;;
    remove)   cmd_remove   "$2" ;;
    list)     cmd_list         ;;
    search)   cmd_search   "$2" ;;
    create)   cmd_create   "$2" ;;
    init)     cmd_init         ;;
    info)     cmd_info     "$2" ;;
    update)   cmd_update       ;;
    version)  cmd_version      ;;
    --version)cmd_version      ;;
    *)        help_msg         ;;
esac
