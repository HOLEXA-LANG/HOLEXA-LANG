fn is_keyword(word: String) -> Bool {
    if word == "let"      { return true }
    if word == "const"    { return true }
    if word == "fn"       { return true }
    if word == "return"   { return true }
    if word == "if"       { return true }
    if word == "else"     { return true }
    if word == "while"    { return true }
    if word == "for"      { return true }
    if word == "loop"     { return true }
    if word == "break"    { return true }
    if word == "continue" { return true }
    if word == "class"    { return true }
    if word == "import"   { return true }
    if word == "true"     { return true }
    if word == "false"    { return true }
    if word == "none"     { return true }
    if word == "and"      { return true }
    if word == "or"       { return true }
    if word == "not"      { return true }
    if word == "in"       { return true }
    if word == "try"      { return true }
    if word == "catch"    { return true }
    if word == "return"   { return true }
    if word == "self"     { return true }
    return false
}

fn make_token(tok_type: String, value: String, line: Int) -> String {
    return "[" + tok_type + "|" + value + "|" + str(line) + "]"
}

fn tokenize(source: String) -> String {
    let result = ""
    let i = 0
    let line = 1
    let length = len(source)

    print("HOLEXA Self-Hosted Lexer v1.0.0")
    print("Tokenizing " + str(length) + " characters...")

    while i < length {
        let ch = "?"
        // We process character by character using index

        // Numbers
        if is_digit(ch) {
            let num = ""
            while i < length and is_digit(ch) {
                num = num + ch
                i = i + 1
            }
            result = result + make_token("INT", num, line) + " "
        }

        i = i + 1
    }

    return result
}

