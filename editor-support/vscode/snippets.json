{
    "HOLEXA Main Function": {
        "prefix": "main",
        "body": ["fn main() {", "    $0", "}"],
        "description": "Main function"
    },
    "HOLEXA Function": {
        "prefix": "fn",
        "body": ["fn ${1:name}(${2:params}) -> ${3:None} {", "    $0", "}"],
        "description": "Function"
    },
    "HOLEXA Let": {
        "prefix": "let",
        "body": ["let ${1:name} = ${2:value}"],
        "description": "Variable"
    },
    "HOLEXA If": {
        "prefix": "if",
        "body": ["if ${1:condition} {", "    $0", "}"],
        "description": "If statement"
    },
    "HOLEXA If Else": {
        "prefix": "ife",
        "body": ["if ${1:condition} {", "    $2", "} else {", "    $0", "}"],
        "description": "If else"
    },
    "HOLEXA For Loop": {
        "prefix": "for",
        "body": ["for ${1:i} in ${2:0}..${3:10} {", "    $0", "}"],
        "description": "For loop"
    },
    "HOLEXA While Loop": {
        "prefix": "while",
        "body": ["while ${1:condition} {", "    $0", "}"],
        "description": "While loop"
    },
    "HOLEXA Class": {
        "prefix": "class",
        "body": [
            "class ${1:Name} {",
            "    ${2:field}: ${3:String}",
            "",
            "    fn new(${2:field}: ${3:String}) -> ${1:Name} {",
            "        return ${1:Name} { ${2:field}: ${2:field} }",
            "    }",
            "",
            "    fn ${4:method}(self) -> ${5:None} {",
            "        $0",
            "    }",
            "}"
        ],
        "description": "Class"
    },
    "HOLEXA Try Catch": {
        "prefix": "try",
        "body": [
            "try {",
            "    $1",
            "} catch err {",
            "    print(err.message)",
            "}"
        ],
        "description": "Try catch"
    },
    "HOLEXA Print": {
        "prefix": "print",
        "body": ["print(${1:\"message\"})"],
        "description": "Print"
    },
    "HOLEXA Import": {
        "prefix": "import",
        "body": ["import ${1:module}"],
        "description": "Import"
    },
    "HOLEXA Async Function": {
        "prefix": "async",
        "body": ["async fn ${1:name}(${2:params}) -> ${3:None} {", "    $0", "}"],
        "description": "Async function"
    }
}
