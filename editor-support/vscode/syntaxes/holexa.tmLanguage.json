{
    "name": "HOLEXA",
    "scopeName": "source.hlx",
    "fileTypes": ["hlx"],
    "patterns": [
        { "include": "#comments" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#functions" },
        { "include": "#constants" },
        { "include": "#operators" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.hlx",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.hlx",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.hlx",
                    "match": "\\b(if|else|while|for|loop|break|continue|return|match|in)\\b"
                },
                {
                    "name": "keyword.declaration.hlx",
                    "match": "\\b(let|const|fn|class|trait|implements|async|await|spawn)\\b"
                },
                {
                    "name": "keyword.other.hlx",
                    "match": "\\b(import|from|try|catch|finally|raise|extern|self)\\b"
                },
                {
                    "name": "constant.language.hlx",
                    "match": "\\b(true|false|none)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "support.type.hlx",
                    "match": "\\b(Int|Float|String|Bool|List|Map|None|Any|Byte)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.hlx",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.hlx",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.float.hlx",
                    "match": "\\b[0-9]+\\.[0-9]+\\b"
                },
                {
                    "name": "constant.numeric.integer.hlx",
                    "match": "\\b[0-9]+\\b"
                }
            ]
        },
        "functions": {
            "patterns": [
                {
                    "name": "entity.name.function.hlx",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*\\()"
                },
                {
                    "name": "entity.name.type.class.hlx",
                    "match": "(?<=class\\s)[a-zA-Z_][a-zA-Z0-9_]*"
                },
                {
                    "name": "entity.name.function.definition.hlx",
                    "match": "(?<=fn\\s)[a-zA-Z_][a-zA-Z0-9_]*"
                }
            ]
        },
        "constants": {
            "patterns": [
                {
                    "name": "variable.other.constant.hlx",
                    "match": "\\b[A-Z][A-Z0-9_]+\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.hlx",
                    "match": "(->|\\.\\.|\\.)|[+\\-*/%=<>!&|^~]+"
                }
            ]
        }
    }
}
