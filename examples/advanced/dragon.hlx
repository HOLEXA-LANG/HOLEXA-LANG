fn main() {
    let name = "Dragon"
    let msg = "Hello " + name
    print(msg)

    let x = 10
    if x > 5 {
        print("x is big")
    } else {
        print("x is small")
    }

    for i in 0..5 {
        print(i)
    }

    try {
        print("trying")
    } catch err {
        print("error")
    }

    print("Done!")
}
