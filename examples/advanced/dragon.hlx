fn greet(name: String) -> String {
    return "Hello " + name
}

fn main() {
    let x = 10
    let msg = greet("Dragon")
    print(msg)

    if x > 5 {
        print("x is big")
    } else {
        print("x is small")
    }

    for i in 0..5 {
        print(i)
    }

    try {
        print("trying")
    } catch err {
        print("error")
    }

    print("Done!")
}
