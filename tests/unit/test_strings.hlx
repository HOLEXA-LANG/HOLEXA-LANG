// HOLEXA Unit Tests — Strings
fn test_string_ops() {
    let s = "Hello HOLEXA"
    print("Original:  " + s)
    print("Length:    " + str(len(s)))
    print("Concat:    " + s + " Dragon!")
    print("Repeat:    " + s + s)
}

fn test_string_convert() {
    let n = 42
    let f = 3.14
    let b = true
    print("Int->Str:   " + str(n))
    print("Float->Str: " + str(f))
    print("Bool->Str:  " + str(b))
}

fn main() {
    print("=== String Tests ===")
    test_string_ops()
    test_string_convert()
    print("=== PASS ===")
}
